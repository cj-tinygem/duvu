{
  "name": "duvu",
  "version": "19.0.0",
  "description": "DUVU — 범용 디자인 시스템 엔진. AI 에이전트와 사람 모두를 위한 디자인 토큰/프리셋/템플릿 CLI.",
  "license": "MIT",
  "author": "tinygem <cj@tinygem.ai>",
  "bin": {
    "duvu": "./bin/duvu.js"
  },
  "type": "module",
  "keywords": ["design-system", "design-tokens", "css", "tailwind", "flutter", "swiftui", "unity", "ai-skill", "claude-code", "codex", "gemini"],
  "files": ["bin/duvu.js", "bin/screenshot.js", "bin/link-smoke.js", "bin/package-smoke.js", "bin/security-smoke.js", "data/", "demo/index.html", "skills/", "README.md"],
  "dependencies": {
    "puppeteer-core": "^24.42.0"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/duvu.js",
    "demo": "node bin/duvu.js demo",
    "screenshot": "node bin/screenshot.js --quick",
    "test": "node bin/duvu.js audit && node bin/duvu.js show clone osmo >/dev/null && node bin/duvu.js generate toss --platform react-native >/dev/null && npm run test:links && npm run test:package && npm run test:security",
    "test:links": "node bin/link-smoke.js",
    "test:package": "node bin/package-smoke.js",
    "test:security": "node bin/security-smoke.js"
  }
}
